FROM bw-rust-base:latest AS builder

WORKDIR /src

COPY rust/Cargo.toml /src/Cargo.toml
COPY rust/Cargo.lock* /src/
COPY rust/bw-core /src/bw-core
COPY rust/services /src/services
COPY proto /proto

RUN cargo build --release -p orchestrator -p worker -p assignment


FROM debian:bookworm-slim

WORKDIR /app

COPY --from=builder /src/target/release/orchestrator /app/orchestrator
COPY --from=builder /src/target/release/worker /app/worker
COPY --from=builder /src/target/release/assignment /app/assignment

RUN mkdir -p /app/out

CMD ["/app/orchestrator"]