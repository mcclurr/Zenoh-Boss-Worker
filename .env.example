RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

ZENOH_ENDPOINT=tcp/zenoh:7447

JOBS_QUEUE=jobs
RESULTS_QUEUE=results

JOBS_BATCH_KEY=demo/input/jobs
